{
  "openapi": "3.1.0",
  "info": {
    "title": "Crash Reporter API",
    "description": "API for receiving and managing crash reports.",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/instance": {
      "post": {
        "summary": "Create Instance",
        "operationId": "create_instance_api_v1_instance_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InstanceCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InstanceCreateResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/report": {
      "post": {
        "summary": "Create Report",
        "operationId": "create_report_api_v1_report_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReportCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportOut"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "InstanceCreate": {
        "properties": {
          "project_id": {
            "type": "string",
            "title": "Project Id"
          },
          "notes": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Notes"
          }
        },
        "type": "object",
        "required": [
          "project_id"
        ],
        "title": "InstanceCreate"
      },
      "InstanceCreateResponse": {
        "properties": {
          "instance_uuid": {
            "type": "string",
            "title": "Instance Uuid"
          },
          "token": {
            "type": "string",
            "title": "Token"
          }
        },
        "type": "object",
        "required": [
          "instance_uuid",
          "token"
        ],
        "title": "InstanceCreateResponse"
      },
      "InstanceOut": {
        "properties": {
          "uuid": {
            "type": "string",
            "title": "Uuid"
          },
          "project_uuid": {
            "type": "string",
            "title": "Project Uuid"
          },
          "notes": {
            "type": "string",
            "title": "Notes"
          }
        },
        "type": "object",
        "required": [
          "uuid",
          "project_uuid",
          "notes"
        ],
        "title": "InstanceOut"
      },
      "InstanceQueryResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/InstanceOut"
            },
            "type": "array",
            "title": "Items"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          },
          "page": {
            "type": "integer",
            "title": "Page"
          },
          "resultsperpage": {
            "type": "integer",
            "title": "Resultsperpage"
          }
        },
        "type": "object",
        "required": [
          "items",
          "total",
          "page",
          "resultsperpage"
        ],
        "title": "InstanceQueryResponse"
      },
      "InstanceUpdate": {
        "properties": {
          "notes": {
            "type": "string",
            "title": "Notes"
          }
        },
        "type": "object",
        "required": [
          "notes"
        ],
        "title": "InstanceUpdate"
      },
      "LoginRequest": {
        "properties": {
          "username": {
            "type": "string",
            "title": "Username"
          },
          "password": {
            "type": "string",
            "title": "Password"
          }
        },
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "title": "LoginRequest"
      },
      "ProjectCreate": {
        "properties": {
          "project_id": {
            "type": "string",
            "pattern": "^[a-z0-9_-]+$",
            "title": "Project Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          }
        },
        "type": "object",
        "required": [
          "project_id",
          "name"
        ],
        "title": "ProjectCreate"
      },
      "ProjectOut": {
        "properties": {
          "uuid": {
            "type": "string",
            "title": "Uuid"
          },
          "project_id": {
            "type": "string",
            "title": "Project Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          }
        },
        "type": "object",
        "required": [
          "uuid",
          "project_id",
          "name"
        ],
        "title": "ProjectOut"
      },
      "ProjectQueryResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/ProjectOut"
            },
            "type": "array",
            "title": "Items"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          },
          "page": {
            "type": "integer",
            "title": "Page"
          },
          "resultsperpage": {
            "type": "integer",
            "title": "Resultsperpage"
          }
        },
        "type": "object",
        "required": [
          "items",
          "total",
          "page",
          "resultsperpage"
        ],
        "title": "ProjectQueryResponse"
      },
      "ProjectUpdate": {
        "properties": {
          "project_id": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^[a-z0-9_-]+$"
              },
              {
                "type": "null"
              }
            ],
            "title": "Project Id"
          },
          "name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Name"
          }
        },
        "type": "object",
        "title": "ProjectUpdate"
      },
      "ReportCreate": {
        "properties": {
          "instance_uuid": {
            "type": "string",
            "title": "Instance Uuid"
          },
          "severity": {
            "type": "string",
            "pattern": "^(low|medium|high|critical)$",
            "title": "Severity"
          },
          "metadata": {
            "additionalProperties": true,
            "type": "object",
            "title": "Metadata"
          }
        },
        "type": "object",
        "required": [
          "instance_uuid",
          "severity"
        ],
        "title": "ReportCreate"
      },
      "ReportOut": {
        "properties": {
          "uuid": {
            "type": "string",
            "title": "Uuid"
          },
          "project_uuid": {
            "type": "string",
            "title": "Project Uuid"
          },
          "instance_uuid": {
            "type": "string",
            "title": "Instance Uuid"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp"
          },
          "severity": {
            "type": "string",
            "title": "Severity"
          },
          "metadata": {
            "additionalProperties": true,
            "type": "object",
            "title": "Metadata"
          }
        },
        "type": "object",
        "required": [
          "uuid",
          "project_uuid",
          "instance_uuid",
          "timestamp",
          "severity",
          "metadata"
        ],
        "title": "ReportOut"
      },
      "ReportQueryResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/ReportOut"
            },
            "type": "array",
            "title": "Items"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          },
          "page": {
            "type": "integer",
            "title": "Page"
          },
          "resultsperpage": {
            "type": "integer",
            "title": "Resultsperpage"
          }
        },
        "type": "object",
        "required": [
          "items",
          "total",
          "page",
          "resultsperpage"
        ],
        "title": "ReportQueryResponse"
      },
      "ReportUpdate": {
        "properties": {
          "metadata": {
            "additionalProperties": true,
            "type": "object",
            "title": "Metadata"
          }
        },
        "type": "object",
        "title": "ReportUpdate"
      },
      "TokenResponse": {
        "properties": {
          "access_token": {
            "type": "string",
            "title": "Access Token"
          },
          "token_type": {
            "type": "string",
            "title": "Token Type",
            "default": "bearer"
          },
          "expires_in_seconds": {
            "type": "integer",
            "title": "Expires In Seconds"
          }
        },
        "type": "object",
        "required": [
          "access_token",
          "expires_in_seconds"
        ],
        "title": "TokenResponse"
      },
      "UserCreate": {
        "properties": {
          "username": {
            "type": "string",
            "title": "Username"
          },
          "password": {
            "type": "string",
            "title": "Password"
          }
        },
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "title": "UserCreate"
      },
      "UserOut": {
        "properties": {
          "uuid": {
            "type": "string",
            "title": "Uuid"
          },
          "username": {
            "type": "string",
            "title": "Username"
          }
        },
        "type": "object",
        "required": [
          "uuid",
          "username"
        ],
        "title": "UserOut"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}